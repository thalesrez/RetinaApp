# .env.example — vai para o Git (sem valores reais)
# Copie para .env.local e preencha os valores reais.
# NUNCA commite .env.local

# Banco de Dados
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/retinaapp_dev

# Redis
REDIS_URL=redis://HOST:PORT

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Pagar.me
PAGARME_API_KEY=ak_...
PAGARME_WEBHOOK_SECRET=...
PAGARME_PLAN_ID_MENSAL=...
PAGARME_PLAN_ID_ANUAL=...
PAGARME_PLAN_ID_ALUMNI=...

# AWS S3 + CloudFront
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=retinaapp-imagens
AWS_REGION=us-east-1
AWS_CLOUDFRONT_URL=https://XXXXX.cloudfront.net

# SMTP (nodemailer)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@exemplo.com
SMTP_PASS=senha-smtp
SMTP_FROM=RetinaApp <noreply@retinaapp.com.br>

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ORG=retinaapp
SENTRY_PROJECT=retinaapp-nextjs
SENTRY_AUTH_TOKEN=sntrys_...

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RetinaApp
